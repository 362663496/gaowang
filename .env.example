POSTGRES_DB=gaowang
POSTGRES_USER=gaowang
POSTGRES_PASSWORD=local-dev-password
POSTGRES_PORT=5432
HTTP_PORT=80
DATABASE_URL=host=postgres user=gaowang password=local-dev-password dbname=gaowang port=5432 sslmode=disable TimeZone=Asia/Shanghai
API_ADDR=:8080
# At least 32 bytes. Rotating AUTH_SECRET invalidates all sessions.
AUTH_SECRET=local-dev-auth-secret-at-least-32-bytes
# Create the first admin only when the users table is empty. Remove INITIAL_ADMIN_PASSWORD after the first successful start.
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
# Local HTTP should keep this false. Production HTTPS must set true.
SESSION_COOKIE_SECURE=false
UPLOAD_DIR=/app/uploads
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=7
BACKUP_ATTACHMENT_LIMIT_MB=20
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=backup@example.com
SMTP_PASSWORD=example-smtp-password
SMTP_FROM=backup@example.com
SMTP_TO=owner@example.com
SMTP_TLS=starttls
NEXT_PUBLIC_API_BASE_URL=/api/v1
